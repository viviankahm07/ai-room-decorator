# OpenAI API Key - get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Unsplash API Key - free at https://unsplash.com/developers (enables Pinterest-style inspiration photos)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Etsy API Key - free at https://etsy.com/developers (enables Moodboard 1 live products)
ETSY_API_KEY=your-etsy-api-key

# eBay API - free at https://developer.ebay.com (enables Moodboard 2 live products)
# Create an app at developer.ebay.com → get Client ID (App ID) + Client Secret (Cert ID)
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id

# Optional: Supabase for persisted boards (falls back to localStorage if not set)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

